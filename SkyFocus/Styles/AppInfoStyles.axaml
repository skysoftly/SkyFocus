<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SkyFocus.Controls">
    <Design.PreviewWith>
        <Grid Width="1920" Height="1080">
            
            <Grid ColumnDefinitions="* *" RowDefinitions="Auto *" Margin="5"
                  IsVisible="True">
                <StackPanel Orientation="Vertical" Margin="20" Spacing="30">
                    <StackPanel Orientation="Horizontal" Spacing="30" Margin="10">
                        <Image Source="/Assets/icon.png" Height="40" Width="40" />
                        <StackPanel>
                            <TextBlock Text="SkyFocus" FontSize="20" />
                        </StackPanel>
                    </StackPanel>
                    <Grid ColumnDefinitions="* 50" ColumnSpacing="10">
                        <Button Grid.Column="0" 
                                Classes="app-toggle"
                                HorizontalAlignment="Stretch"
                                Height="50">
                            <controls:StateTextBlock
                                ActiveText="✕ Закрыть"
                                InactiveText="▶ Запустить"
                                Classes="app-toggle"/>
                        </Button>
                        <Button Grid.Column="1" HorizontalAlignment="Stretch" Height="50"
                                Content="-"/>
                    </Grid>
                </StackPanel>

            </Grid>
        </Grid>
    </Design.PreviewWith>

    <!-- Add Styles Here -->
    
    <Style Selector="TextBlock.app-name">
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="Button.app-toggle-on">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="#A8343C"/>
        
        
        <Style Selector="^:pointerover /template/ContentPresenter">
            <Setter Property="Background" Value="#d7424d" />
        </Style>
        <Style Selector="^:pressed /template/ContentPresenter">
            <Setter Property="Background" Value="#8b272e" />
        </Style>
    </Style>
    <Style Selector="Button.app-toggle-off">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="#FF6B3596"/>
        
        <Style Selector="^:pointerover /template/ContentPresenter">
            <Setter Property="Background" Value="#9252c7" />
        </Style>
        <Style Selector="^:pressed /template/ContentPresenter">
            <Setter Property="Background" Value="#592880" />
        </Style>
    </Style>
    <Style Selector="controls|StateTextBlock.app-toggle">
        <Setter Property="FontSize" Value="20"/>
        
        <Style Selector="^:checked">
            <Setter Property="FontSize" Value="20" />
        </Style>
    </Style>
    <Style Selector="Button.app-info">
        <Setter Property="CornerRadius" Value="10"/>
    </Style>
    
    
    
    <Style Selector="controls|StateTextBlock.app-state">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Foreground" Value="#9E9E9E" />
        
        <Style Selector="^:checked">
            <Setter Property="Foreground" Value="#4CAF50" />
        </Style>
    </Style>
    
    
    <Style Selector="ToggleButton.favorite-toggle">
        <Setter Property="FontSize" Value="25" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        
        
        <Style Selector="^:pointerover /template/ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="^:checked /template/ContentPresenter">
            <Setter Property="Content" Value="★" />
            <Setter Property="Foreground" Value="Gold" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="^:unchecked /template/ContentPresenter">
            <Setter Property="Content" Value="☆" />
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Style>

    
    
    <Style Selector="TextBlock.caption-white">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="LightGray" />
    </Style>
    
    <Style Selector="SelectableTextBlock.caption-white">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="LightGray" />
    </Style>


    
    <Style Selector="Button.copy">
        <Setter Property="Padding" Value="5" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#a08351a9" />

        <Style Selector="^:pointerover /template/ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#b08246af" />
        </Style>
        <Style Selector="^:pressed /template/ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#b0643489" />
        </Style>
    </Style>

</Styles>
