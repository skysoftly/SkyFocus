<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:utils="clr-namespace:SkyFocus.Utils"
        xmlns:controls="clr-namespace:SkyFocus.Controls"
        xmlns:vm="using:SkyFocus.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
        
        MinWidth="1200"
        MinHeight="750"
        x:Class="SkyFocus.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/icon.ico"
        Title="SkyFocus"
        WindowDecorations="BorderOnly"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="50">

    <Grid>
        <Image Source="/Assets/bg.jpg" Stretch="UniformToFill" />
        <Border Classes="Overlay">
            <Grid RowDefinitions="50 * 40"
                  Margin="0,0,8,0">
                <ContentControl Content="{Binding WindowBar}" />
                <Grid Grid.Row="1" RowDefinitions=" *"
                      ColumnDefinitions="50 *">

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*" MinHeight="410" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" MinHeight="160" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="400" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="2*" MinWidth="700" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Classes="Tile">
                                <!-- <ContentControl Margin="10" Content="{Binding AppsList}" /> -->
                            </Border>
                            <Border Grid.Column="2" Classes="Tile">

                                <!-- <ContentControl Content="{Binding AppInfo}" /> -->

                            </Border>

                            <GridSplitter Grid.Column="1"
                                          Classes="TileSplitter VerticalTileSplitter"
                                          ResizeDirection="Columns" />
                        </Grid>

                        <GridSplitter Grid.Row="1"
                                      Classes="TileSplitter HorizontalTileSplitter"
                                      ResizeDirection="Rows" />

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="240" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" MinWidth="240" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Classes="Tile">

                            </Border>
                            <Border Grid.Column="2" Classes="Tile">

                            </Border>

                            <GridSplitter Grid.Column="1"
                                          Classes="TileSplitter VerticalTileSplitter"
                                          ResizeDirection="Columns" />
                        </Grid>
                    </Grid>
                </Grid>
                <Grid Grid.Row="2"
                      VerticalAlignment="Center" Margin="5"
                      ColumnDefinitions="Auto *"
                      ColumnSpacing="10">
                    <Border Classes="Tile" Padding="10 5" VerticalAlignment="Center" Width="170">
                        <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center">
                            <controls:StateTextBlock ActiveText="●" InactiveText="●" Classes="caption_color"
                                                     IsChecked="{Binding TrackingService.IsRunning}" />
                            <controls:StateTextBlock ActiveText="Отслеживание активно"
                                                     InactiveText="Отслеживание не активно"
                                                     Classes="caption"
                                                     IsChecked="{Binding TrackingService.IsRunning}" />
                        </StackPanel>
                    </Border>
                    <Grid Grid.Column="1"
                          ColumnDefinitions="* *"
                          Margin="10 5"
                          VerticalAlignment="Center">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="⟳" Classes="caption" FontSize="16" Margin="0 -6 0 0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Синхронизация: 2 мин. назад" Classes="caption" VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20" HorizontalAlignment="Right">


                            <TextBlock Text="{x:Static utils:AppInfo.Version}" Classes="caption"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="⫶☰" Classes="caption" FontSize="20" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                </Grid>
            </Grid>
        </Border>
        
        <ContentControl Content="{Binding Overlay}"/>
    </Grid>
</Window>