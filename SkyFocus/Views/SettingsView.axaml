<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SkyFocus.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SkyFocus.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <Border Classes="Overlay" IsVisible="{Binding IsVisible}" Padding="0 50 10 0">
        <Grid>
            <Button Command="{Binding DisableCommand}" Content="x" Width="100" Height="100"/>
        </Grid>
    </Border>
</UserControl>