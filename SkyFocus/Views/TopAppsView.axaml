<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SkyFocus.ViewModels"
             xmlns:controls="clr-namespace:SkyFocus.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SkyFocus.Views.TopAppsView"
             x:DataType="vm:TopAppsViewModel">
    <StackPanel Margin="10" Spacing="10">
        <Grid ColumnDefinitions="* *">
            <TextBlock Text="Топ приложений" Classes="h5" VerticalAlignment="Center" />
            <ComboBox Grid.Column="1" HorizontalAlignment="Right" ItemsSource="{Binding Periods}"
                      SelectedItem="{Binding SelectedPeriod}"
                      DisplayMemberBinding="{Binding DisplayName}"
                      Padding="10,6"
                      CornerRadius="6" />
        </Grid>
        <ItemsControl ItemsSource="{Binding TopApps}" HorizontalAlignment="Left">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="5" Rows="1" ColumnSpacing="10"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Classes="TileInto" Height="80">
                        <Grid RowDefinitions="* * *" VerticalAlignment="Center" Margin="10 0" RowSpacing="5">
                            <Grid ColumnDefinitions="Auto *">
                                <TextBlock Text="{Binding Rank}" />
                                <Image Grid.Column="1" Source="{Binding App.Icon}" Width="30" Height="30" />
                            </Grid>
                            <TextBlock Grid.Row="1" Text="{Binding App.Name}" />
                            <TextBlock Grid.Row="2"
                                       Text="{Binding TotalSeconds, Converter={StaticResource SecondsToTimeString}}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>