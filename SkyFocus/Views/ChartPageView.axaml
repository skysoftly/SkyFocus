<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:vm="using:SkyFocus.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SkyFocus.Views.ChartPageView"
             x:DataType="vm:ChartPageViewModel">
    <Border Grid.Column="0" Classes="Tile">
        <Grid RowDefinitions="Auto *">
            <Grid ColumnDefinitions="* *" Margin="10">
                <TextBlock Grid.Column="0" Text="Общая статистика пользования" Classes="h4" />
                <ComboBox Grid.Column="1" HorizontalAlignment="Right" ItemsSource="{Binding Periods}"
                          SelectedItem="{Binding SelectedPeriod}"
                          DisplayMemberBinding="{Binding DisplayName}"
                          Padding="10,6"
                          CornerRadius="6" />
            </Grid>
            <lvc:CartesianChart Grid.Row="1"
                                Series="{Binding Series}"
                                ZoomMode="{Binding ZoomMode}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding YAxes}">
            </lvc:CartesianChart>
        </Grid>
    </Border>
</UserControl>