<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SkyFocus.App"
             xmlns:local="using:SkyFocus"
             xmlns:converters="using:SkyFocus.Converters"
             RequestedThemeVariant="Dark">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->


    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>
    
    <Application.Resources>
        <converters:SecondsToTimeStringConverter x:Key="SecondsToTimeString" />
    </Application.Resources>
    
    
    <Application.Styles>
        <!-- Тема -->
        <FluentTheme />
        
        <!-- ⭐ ВСЕ СТИЛИ ЗДЕСЬ -->
        <StyleInclude Source="avares://SkyFocus/Styles/MainStyles.axaml" />
        <StyleInclude Source="avares://SkyFocus/Styles/AppsListStyles.axaml" />
        <StyleInclude Source="avares://SkyFocus/Styles/ChartStyles.axaml" />
        <StyleInclude Source="avares://SkyFocus/Styles/AppInfoStyles.axaml" />
    </Application.Styles>
</Application>